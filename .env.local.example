# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI Story Generation (Anthropic Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key

# AI Image Generation (Replicate)
REPLICATE_API_TOKEN=your-replicate-api-token

# Permanent Image Storage (Cloudflare R2 - S3 Compatible)
# Get these from: https://dash.cloudflare.com/[account]/r2/overview/api-tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=ai-childrens-books
R2_PUBLIC_URL=https://your-custom-domain.com # Optional: custom domain for public access

# Audio Narration (ElevenLabs TTS)
# Get your API key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key
